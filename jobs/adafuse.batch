#!/bin/bash
###############################################################################
# Batch AdaFuse — démo bande passante + décision de fusion (heuristique / HF LLM)
#
# Soumission (chemins absolus : fonctionne même si le shell n'est pas à la racine git) :
#   sbatch /raid/home/students/lahrach_cha/ChakibProjects/adafuse/jobs/adafuse.batch
# Heuristique seule (sans appel HF) :  ADAFUSE_NO_LLM=1 sbatch .../jobs/adafuse.batch
#
# Depuis la racine du dépôt uniquement :
#   sbatch jobs/adafuse.batch
#
# Le token Hugging Face doit être dans .env (HUGGINGFACEHUB_API_TOKEN) à la racine
# du dépôt, ou exporté avant soumission.
###############################################################################
#SBATCH --job-name=adafuse
#SBATCH --output=/raid/home/students/lahrach_cha/ChakibProjects/adafuse/jobs/logs/output/adafuse.out
#SBATCH --error=/raid/home/students/lahrach_cha/ChakibProjects/adafuse/jobs/logs/error/adafuse.err
## Partition GPU (prod10, prod20, prod40, prod80)
#SBATCH --partition=prod10
#SBATCH --gres=gpu:nvidia_a100_1g.10gb:1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --time=01:00:00

REPO_ROOT="/raid/home/students/lahrach_cha/ChakibProjects/adafuse"
set -euo pipefail
export PYTHONUNBUFFERED=1
echo "[$(date)] Démarrage du job adafuse (job ${SLURM_JOB_ID:-no_slurm})"

###############################################################################
# 1. Dépôt
###############################################################################
cd "${REPO_ROOT}"
mkdir -p jobs/logs/output jobs/logs/error
echo "Répertoire de travail : $(pwd)"

###############################################################################
# 2. Conda
###############################################################################
source ~/miniforge3/etc/profile.d/conda.sh
conda activate opencood
echo "Python : $(which python)"
echo "Env conda : $CONDA_DEFAULT_ENV"

###############################################################################
# 3. GPU (optionnel pour la démo AdaFuse ; utile si extension locale)
###############################################################################
echo "GPU disponible :"
nvidia-smi --query-gpu=name,memory.total --format=csv,noheader || true
python -c "import torch; print('CUDA:', torch.cuda.is_available()); print('GPU:', torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'N/A')"

###############################################################################
# 4. LLM Hugging Face (Meta-Llama-3-8B-Instruct) — utilisé par défaut si le token est dans .env
#    Heuristique uniquement : export ADAFUSE_NO_LLM=1 avant sbatch
###############################################################################
EXTRA_ARGS=()
if [[ "${ADAFUSE_NO_LLM:-0}" == "1" ]]; then
  EXTRA_ARGS+=(--no-llm)
fi

###############################################################################
# 5. Démo AdaFuse
###############################################################################
echo "[$(date)] Lancement : python scripts/run_adafuse_demo.py ${EXTRA_ARGS[*]}"
python scripts/run_adafuse_demo.py "${EXTRA_ARGS[@]}"

echo "[$(date)] Fin du job adafuse"
