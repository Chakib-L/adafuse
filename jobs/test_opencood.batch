#!/bin/bash
###############################################################################
# Batch script pour tester OpenCOOD sur le cluster DGX
# Exemple d'utilisation (SLURM) :
#   sbatch jobs/test_opencood.batch
#   sbatch jobs/test_opencood.batch --fusion_method intermediate
#
###############################################################################
# Nom du job et fichiers de log
#SBATCH --job-name=opencood_test
#SBATCH --output=jobs/logs/output/test_opencood.out
#SBATCH --error=jobs/logs/error/test_opencood.err
## Partition GPU (prod10, prod20, prod40, prod80)
#SBATCH --partition=prod10
## GRES GPU correspondant à la partition
#SBATCH --gres=gpu:nvidia_a100_1g.10gb:1
## CPU
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
## Limite de temps
#SBATCH --time=01:00:00

set -euo pipefail
export PYTHONUNBUFFERED=1
echo "[$(date)] Démarrage du job opencood_test (job ${SLURM_JOB_ID:-no_slurm})"

###############################################################################
# 1. Positionnement dans le dépôt
###############################################################################
cd /raid/home/students/lahrach_cha/ChakibProjects/adafuse
echo "Répertoire de travail : $(pwd)"

###############################################################################
# 2. Activation de l'environnement conda
###############################################################################
source ~/miniforge3/etc/profile.d/conda.sh
conda activate opencood
echo "Python : $(which python)"
echo "Env conda : $CONDA_DEFAULT_ENV"

###############################################################################
# 4. Vérification GPU
###############################################################################
echo "GPU disponible :"
nvidia-smi --query-gpu=name,memory.total --format=csv,noheader
python -c "import torch; print('CUDA:', torch.cuda.is_available()); print('GPU:', torch.cuda.get_device_name(0))"

###############################################################################
# 5. Lancement du test OpenCOOD
###############################################################################
echo "[$(date)] Lancement de la visualisation OpenCOOD..."


python -c "
from opencood.hypes_yaml.yaml_utils import load_yaml
from opencood.data_utils.datasets import build_dataset

params = load_yaml('opencood/hypes_yaml/visualization.yaml')
dataset = build_dataset(params, visualize=True, train=False)
print('Dataset OK — nb scenes:', len(dataset))
item = dataset[0]
print('Premier item chargé OK')
print('Keys:', list(item.keys()))
"



echo "[$(date)] Fin du job opencood_test"